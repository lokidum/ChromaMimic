# ChromaMimic — environment
# Copy to .env.local for local dev, and add the same keys in Vercel → Settings → Environment Variables.
# Without VITE_CLERK_PUBLISHABLE_KEY the app runs the built-in MOCK entitlements
# (full guest → free → pro flow against localStorage). Add the keys to go live.

# --- Frontend (Vite, safe to expose) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- Backend (Vercel serverless functions, SECRET — never expose) ---
CLERK_SECRET_KEY=sk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx
APP_URL=https://chromamimic.com
